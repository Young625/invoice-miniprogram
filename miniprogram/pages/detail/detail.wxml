<!--pages/detail/detail.wxml-->
<view class="container">
  <view wx:if="{{loading}}" class="loading-state">
    <text>加载中...</text>
  </view>

  <view wx:elif="{{invoice}}" class="detail-content">
    <!-- 头部信息 -->
    <view class="detail-header">
      <view class="type-tag">{{invoice.invoice_type || '电子发票'}}</view>
      <view class="amount-section">
        <text class="amount-label">价税合计</text>
        <text class="amount-value">¥{{invoice.total_amount || '0.00'}}</text>
      </view>
    </view>

    <!-- 基本信息 -->
    <view class="info-section">
      <view class="section-title">基本信息</view>
      <view class="info-item">
        <text class="info-label">发票号码</text>
        <view class="info-value-row">
          <text class="info-value">{{invoice.invoice_number}}</text>
          <text class="copy-btn" bindtap="copyInvoiceNumber">复制</text>
        </view>
      </view>
      <view class="info-item">
        <text class="info-label">发票代码</text>
        <text class="info-value">{{invoice.invoice_code || '-'}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">开票日期</text>
        <text class="info-value">{{invoice.invoice_date || '-'}}</text>
      </view>
    </view>

    <!-- 购买方信息 -->
    <view class="info-section">
      <view class="section-title">购买方</view>
      <view class="info-item">
        <text class="info-label">名称</text>
        <text class="info-value">{{invoice.buyer_name || '-'}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">税号</text>
        <text class="info-value">{{invoice.buyer_tax_id || '-'}}</text>
      </view>
    </view>

    <!-- 销售方信息 -->
    <view class="info-section">
      <view class="section-title">销售方</view>
      <view class="info-item">
        <text class="info-label">名称</text>
        <text class="info-value">{{invoice.seller_name || '-'}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">税号</text>
        <text class="info-value">{{invoice.seller_tax_id || '-'}}</text>
      </view>
    </view>

    <!-- 金额信息 -->
    <view class="info-section">
      <view class="section-title">金额明细</view>
      <view class="info-item">
        <text class="info-label">金额</text>
        <text class="info-value">¥{{invoice.amount || '0.00'}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">税额</text>
        <text class="info-value">¥{{invoice.tax_amount || '0.00'}}</text>
      </view>
      <view class="info-item highlight">
        <text class="info-label">价税合计</text>
        <text class="info-value">¥{{invoice.total_amount || '0.00'}}</text>
      </view>
    </view>

    <!-- 商品信息 -->
    <view wx:if="{{invoice.items.length > 0}}" class="info-section">
      <view class="section-title">商品信息</view>
      <view class="items-list">
        <text wx:for="{{invoice.items}}" wx:key="index">{{item}}</text>
      </view>
    </view>

    <!-- 来源信息 -->
    <view class="info-section">
      <view class="section-title">来源信息</view>
      <view class="info-item">
        <text class="info-label">来源类型</text>
        <text class="info-value">{{invoice.source_type === 'attachment' ? '邮件附件' : '链接下载'}}</text>
      </view>
      <view wx:if="{{invoice.email_subject}}" class="info-item">
        <text class="info-label">邮件主题</text>
        <text class="info-value">{{invoice.email_subject}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">提取时间</text>
        <text class="info-value">{{invoice.extracted_at}}</text>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-section">
      <button class="action-btn primary" bindtap="previewPDF">
        <text>查看 PDF</text>
      </button>
      <button class="action-btn secondary" bindtap="markAsExported" disabled="{{invoice.is_exported}}">
        <text>{{invoice.is_exported ? '已导出' : '标记为已导出'}}</text>
      </button>
    </view>
  </view>
</view>