/* pages/detail/detail.wxss - 统一简约风，无纯白 */
page {
  background: linear-gradient(165deg, #F0F4FF 0%, #EEF2F7 40%, #F2F4F8 100%);
}

.loading-state {
  text-align: center;
  padding: 100px 0;
  color: #94A3B8;
}

.detail-content {
  padding: 16px;
}

.detail-header {
  background: linear-gradient(135deg, #3B82F6 0%, #2563EB 50%, #1D4ED8 100%);
  border-radius: 12px;
  padding: 24px;
  text-align: center;
  color: #FFFFFF;
  margin-bottom: 16px;
  box-shadow: 0 4px 14px rgba(37, 99, 235, 0.35);
}

.type-tag {
  display: inline-block;
  padding: 4px 12px;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 8px;
  font-size: 14px;
  margin-bottom: 16px;
}

.amount-section {
  margin-top: 12px;
}

.amount-label {
  display: block;
  font-size: 14px;
  opacity: 0.9;
  margin-bottom: 8px;
}

.amount-value {
  display: block;
  font-size: 36px;
  font-weight: bold;
}

.info-section {
  background: linear-gradient(145deg, #F8FAFC 0%, #F2F4F8 100%);
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  border: 1px solid rgba(226, 232, 240, 0.8);
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 12px;
  padding-bottom: 8px;
  border-bottom: 1px solid #E2E8F0;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
}

.info-item.highlight {
  background: linear-gradient(135deg, #F2F4F8 0%, #EEF2F7 100%);
  margin: 0 -16px;
  padding: 12px 16px;
  border-radius: 8px;
}

.info-label {
  font-size: 14px;
  color: #64748B;
}

.info-value {
  font-size: 14px;
  color: #1E293B;
  font-weight: 500;
}

.info-value-row {
  display: flex;
  align-items: center;
  gap: 8px;
}

.copy-btn {
  padding: 4px 10px;
  background: linear-gradient(135deg, #3B82F6 0%, #2563EB 100%);
  color: #FFFFFF;
  font-size: 12px;
  border-radius: 8px;
}

.items-list {
  font-size: 14px;
  color: #1E293B;
  line-height: 1.8;
}

.action-section {
  margin-top: 24px;
  display: flex;
  gap: 12px;
}

.action-btn {
  flex: 1;
  height: 44px;
  line-height: 44px;
  border-radius: 12px;
  font-size: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.action-btn.primary {
  background: linear-gradient(135deg, #3B82F6 0%, #2563EB 100%);
  color: #FFFFFF;
}

.action-btn.secondary {
  background: linear-gradient(145deg, #F8FAFC 0%, #F2F4F8 100%);
  color: #2563EB;
  border: 1px solid #2563EB;
}

.action-btn[disabled] {
  opacity: 0.5;
}
